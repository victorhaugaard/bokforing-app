# Databas — Neon (gratis på neon.tech)
# Skapa ett projekt på neon.tech, kopiera connection strings härifrån:
# Settings → Connection Details → Connection string (välj "Pooled" för DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# API-nyckel för att skydda API-routes i produktion
# Generera: openssl rand -hex 32
API_SECRET_KEY=din-hemliga-nyckel-här

# Stripe (valfritt)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
